{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "export/**",
              "image-slot.js",
              "ui_kits/oes-global/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto|Roboto Condensed|Poppins))/i]",
        "message": "Font not provided by the design system. Available: Roboto, Roboto Condensed, Poppins."
      },
      {
        "selector": "JSXOpeningElement[name.name='Brand'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|role|tagline|domain|desc|parent|key|ref|className|style|children)$/]",
        "message": "<Brand> doesn't accept that prop. Declared props: id, name, role, tagline, domain, desc, parent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:onSubmit|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: onSubmit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNav|active|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: onNav, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNav|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: onNav."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
